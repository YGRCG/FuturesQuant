# 复制为 .env 并填入真实值（.env 已被 .gitignore 排除）

# 天勤账号（用于行情订阅，必填）
TQ_USERNAME=your_tianqin_username
TQ_PASSWORD=your_tianqin_password

# CTP 期货账户（实盘时填写，仿真模式可不填）
TQ_BROKER_ID=9999              # 模拟: 9999  实盘: 如 2030000099
TQ_ACCOUNT_ID=your_account_id
TQ_ACCOUNT_PASSWORD=your_ctp_password

# 运行模式: sim=仿真(TqSim)  live=实盘(TqAccount)
TQ_MODE=sim

# 风控参数（可按需调整）
RISK_MAX_POSITION_LOTS=10      # 单品种最大持仓手数
RISK_MAX_DRAWDOWN_PCT=0.05     # 最大回撤阈值（超过则停止开新仓）
RISK_DAILY_LOSS_LIMIT=5000     # 单日最大亏损（元，超过则停止所有交易）
RISK_MAX_ORDER_NOTIONAL=500000 # 单笔下单最大名义价值（元）
